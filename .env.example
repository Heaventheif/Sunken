# ==============================
# SunkenBot - متغيرات البيئة
# انسخ هذا الملف باسم .env وأضف قيمك
# على Render: أضفها في Environment Variables
# ==============================

# Facebook Appstate (مطلوب)
# أما ضع المسار كملف appstate.json أو ضع المحتوى هنا
# APPSTATE=[...]

# MongoDB (مطلوب)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/...

# Gemini AI
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# Groq AI
GROQ_API_KEY=

# Pixabay
PIXABAY_API_KEY=

# FerDev API
FERDEV_API_KEY=
FERDEV_API_KEY2=
FERDEV_API_KEY3=

# GitHub Models
GITHUB_MODELS_TOKEN=

# Dashboard Port (افتراضي 5000)
DASHBOARD_PORT=5000

# Node memory limit
NODE_OPTIONS=--max-old-space-size=450

# Dashboard Password (بدلاً من config.json)
DASHBOARD_PASSWORD=your_password_here
